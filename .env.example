# Copy to .env.local and fill in your values.

# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (defaults to gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Optional: Vercel Postgres connection string. Auto-injected by Vercel
# when you attach a Postgres store. Leave unset to use localStorage only.
# POSTGRES_URL=
