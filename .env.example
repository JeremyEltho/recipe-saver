# Copy to .env.local and fill in your values.

# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (defaults to gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite

# Supabase — server-side recipe persistence. Leave unset to use
# browser localStorage only (the app still works without these).
# Find these in Supabase: Project Settings -> API.
# NEXT_PUBLIC_SUPABASE_URL=https://mzdptvbyrijlhdlfhwbx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
